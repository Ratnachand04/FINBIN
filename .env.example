# =========================================================
# BINFIN environment template
# Copy this file to .env and fill in values.
# =========================================================

# -----------------------------
# Application / System
# -----------------------------
# Runtime environment: development or production
ENVIRONMENT=development

# Log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Timezone used by workers, logs, and scheduled jobs
TZ=UTC

# Optional app metadata and bind ports for local runs
APP_NAME=BINFIN
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501


# -----------------------------
# Database / Cache
# -----------------------------
# PostgreSQL credentials used by the postgres container
POSTGRES_USER=binfin
POSTGRES_PASSWORD=binfin
POSTGRES_DB=binfin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full async SQLAlchemy/asyncpg connection string
# Format:
# postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://binfin:binfin@postgres:5432/binfin

# Redis host/port and full URL
REDIS_HOST=redis
REDIS_PORT=6379
# Format: redis://<host>:<port>/<db-index>
REDIS_URL=redis://redis:6379/0


# -----------------------------
# External API Keys
# -----------------------------
# Reddit API (free tier):
# 1) Go to https://www.reddit.com/prefs/apps
# 2) Create "script" app and copy client ID + secret
# 3) Set a descriptive user-agent: app-name/version by username
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=binfin/1.0 by your_reddit_username

# News API key (free tier):
# 1) Sign up at https://newsapi.org/register
# 2) Copy your API key from dashboard
NEWS_API_KEY=your_newsapi_key

# Etherscan API key (free tier):
# 1) Sign up at https://etherscan.io/register
# 2) Create free API key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_key

# Binance keys are optional.
# Keep blank if you only use public endpoints.
# For authenticated endpoints, create keys in Binance API management.
BINANCE_API_KEY=
BINANCE_SECRET=


# -----------------------------
# Ollama / LLM
# -----------------------------
# Internal Ollama URL in docker network
OLLAMA_URL=http://ollama:11434

# Default model pulled by docker compose startup
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M


# -----------------------------
# ML Configuration
# -----------------------------
# Path to local model artifacts/checkpoints
MODEL_PATH=./models

# Set true when GPU acceleration is available and configured
ENABLE_GPU=false

# Batch size used in ML processing worker
BATCH_SIZE=32

# Maximum worker threads/processes for CPU-bound tasks
MAX_WORKERS=4


# -----------------------------
# Trading / Signal Configuration
# -----------------------------
# Comma-separated tickers to monitor
TRACKED_COINS=BTC,ETH,SOL,ADA,DOT

# Minimum confidence threshold for signal publishing (0.0 - 1.0)
MIN_SIGNAL_CONFIDENCE=0.75

# Minimum model/scoring signal strength threshold
MIN_SIGNAL_STRENGTH=7.0


# -----------------------------
# Observability / Dashboards
# -----------------------------
# Grafana default local credentials (change in production)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
